# =============================================================================
# Telegram Personal Assistant — Environment Variables
# Copy this file to .env and fill in your values
# =============================================================================

# LLM Configuration — Chat/Text (OpenAI-compatible API)
LLM_BASE_URL=https://api.tokenfactory.nebius.com/v1/
LLM_API_KEY=your_api_key_here
LLM_CHAT_MODEL=meta-llama/Meta-Llama-3.1-70B-Instruct
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=2048

# LLM Configuration — Vision (leave empty to use LLM_BASE_URL / LLM_API_KEY)
VISION_BASE_URL=https://api.tokenfactory.nebius.com/v1/
VISION_API_KEY=your_api_key_here
LLM_VISION_MODEL=meta-llama/Llama-3.2-90B-Vision-Instruct

# LLM Configuration — Embedding (leave empty to use LLM_BASE_URL / LLM_API_KEY)
EMBEDDING_BASE_URL=https://api.tokenfactory.nebius.com/v1/
EMBEDDING_API_KEY=your_api_key_here
LLM_EMBEDDING_MODEL=BAAI/bge-en-icl
EMBEDDING_DIMENSIONS=4096

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_WEBHOOK_URL=
TELEGRAM_WEBHOOK_SECRET=

# Infrastructure
MONGODB_URI=mongodb://localhost:27017/assistant
REDIS_URL=redis://localhost:6379
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# Default User Settings (overridable per-user in MongoDB)
DEFAULT_TIMEZONE=Asia/Kolkata
DEFAULT_WORKING_HOURS_START=08:00
DEFAULT_WORKING_HOURS_END=23:00
DEFAULT_BUFFER_MINUTES=10
DEFAULT_REMINDER_LEAD_MINUTES=10
DEFAULT_SLACK_PERCENTAGE=20
DEFAULT_MAX_REPLAN_FREQUENCY_MINUTES=5
DEFAULT_DAILY_PLAN_TIME=07:30
DEFAULT_ANALYTICS_TIME=23:30
DEFAULT_SNOOZE_MINUTES=15
DEFAULT_MEMORY_CONFIDENCE_THRESHOLD=0.7
DEFAULT_MEMORY_MIN_DATA_POINTS=3

# Server
PORT=3000
NODE_ENV=development
LOG_LEVEL=info
